{
  "name": "extol",
  "version": "1.4.0",
  "description": "Simple decorator-driven TypeScript externalization library",
  "author": "Csaba Sulyok <csaba.sulyok@gmail.com>",
  "license": "ISC",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "bin": {
    "simple": "./examples/simple.example.ts",
    "simpleobject": "./examples/simpleobject.example.ts",
    "decorator": "./examples/decorator.example.ts",
    "decoratorprefix": "./examples/decoratorprefix.example.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csabasulyok/extol.git"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "clean": "rimraf dist *.tsbuildinfo",
    "build": "tsc -p tsconfig.build.json",
    "cb": "pnpm clean && pnpm build",
    "lint": "eslint 'src/**/*.ts' --quiet --fix",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.ts' --config ./.prettierrc.yml",
    "format:check": "prettier --check .",
    "ci": "pnpm lint && pnpm format && pnpm build",
    "publish:local": "pnpm publish --verbose --registry=http://localhost:8081/repository/npm-releases/",
    "publish:npmjs": "pnpm publish --verbose --registry=https://registry.npmjs.org/",
    "example:simple": "tsx examples/simple.example.ts",
    "example:simpleobject": "tsx examples/simpleobject.example.ts",
    "example:decorator": "DOTENV_CONFIG_PATH=./examples/simple.env tsx examples/decorator.example.ts",
    "example:decoratorprefix": "DOTENV_CONFIG_PATH=./examples/prefixed.env tsx examples/decoratorprefix.example.ts"
  },
  "dependencies": {
    "change-case": "5.4.4",
    "dotenv": "17.3.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "24.12.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unicorn": "63.0.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "npm run lint",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}